# Production Environment Variables for Dr. Codium MVP

# These variables MUST be set before deploying to production.
# Add them to Vercel project settings under "Environment Variables"
# See docs/DEPLOY.md for detailed setup instructions

# ============================================================================
# SUPABASE (Database)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://vlagqisahvksuzghhbnc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# GITHUB APP (PR Webhooks & Polling)
# ============================================================================
GITHUB_APP_ID=12345
GITHUB_APP_PRIVATE_KEY=LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQo...
GITHUB_WEBHOOK_SECRET=your_webhook_secret_minimum_32_chars_here_required

# ============================================================================
# GITHUB OAUTH (User Authentication)
# ============================================================================
GITHUB_OAUTH_CLIENT_ID=Iv1.abc123def456...
GITHUB_OAUTH_CLIENT_SECRET=abc123def456xyz789...
GITHUB_OAUTH_REDIRECT_URI=https://app.dr-codium.com/api/auth/github/callback

# ============================================================================
# GROQ API (LLM for Scoring & Coach Panel)
# ============================================================================
# Get API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_abc123...

# ============================================================================
# COST CONTROLS (Guardrails)
# ============================================================================
WORKSPACE_DAILY_COST_CAP_CENTS=50000    # $500 per day
SCORING_KILL_SWITCH=false                # Set to true to disable scoring

# ============================================================================
# VERCEL (Deployment)
# ============================================================================
VERCEL_URL=https://app.dr-codium.com
CRON_SECRET=your_cron_secret_minimum_32_chars_hex_here_required

# ============================================================================
# MONITORING (Optional)
# ============================================================================
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# DATADOG_API_KEY=your_datadog_api_key
# LOG_LEVEL=info

# ============================================================================
# NOTES
# ============================================================================
# 1. All NEXT_PUBLIC_* variables are exposed to the browser (public)
# 2. Other variables are server-only (private, not exposed to browser)
# 3. Run validation: npm run validate:env
# 4. See docs/DEPLOY.md for setup instructions for each variable
# 5. For GitHub OAuth REDIRECT_URI:
#    - Local dev: http://localhost:3000/api/auth/github/callback
#    - Preview: https://<preview-domain>/api/auth/github/callback
#    - Production: https://app.dr-codium.com/api/auth/github/callback
