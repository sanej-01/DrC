# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vlagqisahvksuzghhbnc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# GitHub App (Phase 3.1 - webhooks)
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY=your_private_key_base64
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# GitHub OAuth (Phase 2.3 - user authentication)
GITHUB_OAUTH_CLIENT_ID=your_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Groq API (for LLM scoring and coaching)
# Get API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# Scoring guardrails (Phase 4.5)
WORKSPACE_DAILY_COST_CAP_CENTS=50000
SCORING_KILL_SWITCH=false

# Vercel deployment
VERCEL_URL=http://localhost:3000

# Vercel Cron (Phase 3.5 - poller)
CRON_SECRET=your_vercel_cron_secret_here
